# Shopify app credentials (Partners Dashboard → your app → API credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# OAuth scopes (must match shopify.app.toml)
SHOPIFY_API_SCOPES=write_products,read_checkout_branding_settings,write_checkout_branding_settings,write_files

# App public URL — set automatically by `shopify app dev` as HOST
# HOST=https://your-tunnel.trycloudflare.com

# Headless storefront URL (admin app + checkout extension default)
NEXT_PUBLIC_STOREFRONT_URL=https://your-store.vercel.app/collections/all

# Checkout UI extension UID (extensions/checkout-ui/shopify.extension.toml → uid)
NEXT_PUBLIC_CHECKOUT_EXTENSION_ID=

# MongoDB for session storage (optional: docker compose up)
DATABASE_URL=mongodb://127.0.0.1:27017/headless-checkout

# Docker Mongo (optional, only if using docker-compose.yml)
# MONGO_INITDB_ROOT_USERNAME=
# MONGO_INITDB_ROOT_PASSWORD=
